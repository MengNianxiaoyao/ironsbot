# 复制此文件为 .env.dev 或 .env.prod 并填写。
# .env 文件无需手动创建，项目已内置。

# === 环境配置 ===
DRIVER=~fastapi+~httpx
HOST=127.0.0.1
PORT=8080
SUPERUSERS=[] # 可选，默认空列表，用于设置超级用户
LOG_LEVEL=INFO          # TRACE / DEBUG / INFO / WARNING / ERROR
COMMAND_START=["/", ""]

# === seer_data 插件（数据库同步与游戏资源图片获取） ===
# 设置 SYNC_URL 后从远程自动拉取并定时更新；留空则从本地文件加载，不自动更新。
SEERAPI_SYNC_URL=https://github.com/SeerAPI/api-data/releases/download/latest/seerapi-data.sqlite
# （可选）用于校验远程同步文件是否需要更新的指纹，留空则跳过验证
SEERAPI_FINGERPRINT_URL=https://github.com/SeerAPI/api-data/releases/download/latest/seerapi-data.sqlite.sha256
SEERAPI_SYNC_INTERVAL_MINUTES=60       # 可选，默认 60，同步间隔（分钟）
SEERAPI_LOCAL_PATH=seerapi-data.sqlite  # 可选，SYNC_URL 为空时的本地回退路径
ALIAS_SYNC_URL=https://github.com/Nattsu39/ironsbot/releases/download/alias-db-latest/aliases-data.sqlite
ALIAS_FINGERPRINT_URL=https://github.com/Nattsu39/ironsbot/releases/download/alias-db-latest/aliases-data.sqlite.sha256
ALIAS_SYNC_INTERVAL_MINUTES=60         # 可选，默认 60，同步间隔（分钟）
ALIAS_LOCAL_PATH=aliases-data.sqlite    # 可选，SYNC_URL 为空时的本地回退路径

# === get_seer_info 插件 ===
RENDER_CACHE_DIR=render_cache          # 可选，图片渲染缓存目录，默认为 nonebot-plugin-localstore 插件中的缓存目录
RENDER_CACHE_MAX_SIZE_MB=200           # 可选，图片渲染缓存最大大小（MB），默认 200

# === 发图插件（以下内容仅作为示例，机器人不提供表情包/图床服务，请自行配置） ===
# 图床后端配置：CNB 图床（仅在命令后端为 cnb 时需要）
SENDPIC_CNB_TOKEN=              # CNB API 令牌
SENDPIC_CNB_REPO=Nattsu39/tudou # CNB 仓库路径

# 图床后端配置：本地文件（仅在命令后端为 local 时需要）
SENDPIC_LOCAL_ROOT=sendpic # 可选，本地图片根目录，默认为 nonebot-plugin-localstore 插件中的data_dir/sendpic目录

# 命令配置：启用哪些命令
SENDPIC_ENABLED_IDS=["tudou","pig","capoo"]

# 命令配置
SENDPIC_CONFIGS=[
    {
        "id": "tudou",
        "backend": "cnb",
        "command": "土豆",
        "aliases": ["今日土豆", "随机土豆", "🥔"],
        "image_dir": "tudou",
        "image_filename_template": "{index}.gif",
        "help_message": "土豆/今日土豆/随机土豆/🥔 <索引(可选)> — 随机或指定索引的土豆表情包",
        "message_template": "{random_text}{command}（{index}/{total}）\n🌈发【{command}x】直接出x号{command}，不加数字默认随机发送\n{image}"
    },
    {
        "id": "pig",
        "backend": "cnb",
        "command": "小猪",
        "aliases": ["今日小猪", "随机小猪", "🐷", "🐖"],
        "image_dir": "pig",
        "image_filename_template": "{index}.jpg",
        "help_message": "小猪/今日小猪/随机小猪/🐷/🐖 <索引(可选)> — 随机或指定索引的小猪表情包",
        "message_template": "{random_text}{command}（{index}/{total}）\n🌈发【{command}x】直接出x号{command}，不加数字默认随机发送\n{image}"
    },
	{
        "id": "capoo",
        "backend": "cnb",
        "command": "咖波",
        "aliases": ["今日咖波", "随机咖波", "capoo", "猫猫虫"],
        "image_dir": "capoo",
        "image_filename_template": "{index}.gif",
        "help_message": "咖波/今日咖波/随机咖波/capoo/猫猫虫 <索引(可选)> — 随机或指定索引的咖波表情包",
        "message_template": "{random_text}{command}（{index}/{total}）\n🌈发【{command}x】直接出x号{command}，不加数字默认随机发送\n{image}"
    }
]

# === 无头赛尔号客户端配置，部分功能需要登录无头客户端获取数据 ===
HEADLESS_SEER_USER_ID=12345678   # 米米号
HEADLESS_SEER_PASSWORD=...  # 密码（明文密码的MD5值）
HEADLESS_SEER_HEARTBEAT_INTERVAL=300  # 心跳间隔（秒）
HEADLESS_SEER_RECONNECT_RETRIES=-1  # 重连尝试次数，-1 表示无限重连
HEADLESS_SEER_RECONNECT_DELAY=5.0  # 重连延迟（秒）
HEADLESS_SEER_RECONNECT_DELAY_MAX=120.0  # 最大重连延迟（秒）